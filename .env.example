# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — Project Settings → API → service_role (SECRET, server-only)
# Used by admin route handlers that must bypass RLS (e.g. bulk operations).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (or your email provider of choice) — used by the order-notification
# Edge Function to email whichever address is set in /admin/settings.
RESEND_API_KEY=your-resend-api-key
